# PostgreSQL
POSTGRES_PORT=5434
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=jobhunterdb

# Published service ports
BACKEND_PORT=5290
UI_PORT=8091

# Backend API URL for the UI (used at Docker build time)
VITE_API_BASE_URL=https://api.tapinti.com

# Production images
BACKEND_IMAGE=ghcr.io/estamedi/jobhunter/backend:latest
UI_IMAGE=ghcr.io/estamedi/jobhunter/ui:latest
