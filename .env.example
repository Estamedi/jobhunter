# PostgreSQL - shared_postgres container on pg_network
POSTGRES_HOST=shared_postgres
POSTGRES_USER=jobhunter_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=jobhunterdb

# Published service ports
BACKEND_PORT=5290
UI_PORT=8091

# Backend API URL for the UI (used at Docker build time)
VITE_API_BASE_URL=https://api.tapinti.com
VITE_GOOGLE_CLIENT_ID=

# Backend Google auth validation
AUTHENTICATION__GOOGLE__CLIENTID=

# Production images
BACKEND_IMAGE=ghcr.io/estamedi/jobhunter/backend:latest
UI_IMAGE=ghcr.io/estamedi/jobhunter/ui:latest
