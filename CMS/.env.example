CMS_IMAGE=ghcr.io/estamedi/cms.tapinti:latest
CMS_PORT=8093

# Secrets — the deploy workflow generates random values on first deploy;
# to set them manually: openssl rand -base64 32 (APP_KEYS takes 4, comma-separated)
APP_KEYS=tobemodified
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database — sqlite (default, stored in the cms_data volume) or postgres
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
# For postgres on the shared container:
# DATABASE_CLIENT=postgres
# DATABASE_HOST=shared_postgres
# DATABASE_PORT=5432
# DATABASE_NAME=tapinti_cms
# DATABASE_USERNAME=jobhunter_user
# DATABASE_PASSWORD=
# DATABASE_SSL=false
